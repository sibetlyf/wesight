# agno-swarm-console Environment Variables

# LLM Provider Configuration
# Use GLM (default) or OpenRouter
LLM_PROVIDER=glm

# GLM API (required when LLM_PROVIDER=glm)
GLM_API_KEY=your_glm_api_key
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_MODEL=glm-4.7

# OpenRouter (required when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=

# Agno OS Bridge
AGNO_OS_BRIDGE_ENABLED=true
AGNO_OS_BASE_URL=http://127.0.0.1:7777
AGNO_OS_AGENT_ID=

# Frontend/Backend Configuration
NEXT_PUBLIC_BACKEND_ORIGIN=http://127.0.0.1:3018
NEXT_PUBLIC_DIRECT_BACKEND_MODE=false

# Optional: Upstash Redis for realtime events
REDIS_URL=
